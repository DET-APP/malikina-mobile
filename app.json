{
  "expo": {
    "name": "Al Moutahabbina",
    "slug": "malikina-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "malikina",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#28655c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.almoutahabbina.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pour calculer les horaires de prière selon votre position.",
        "NSMicrophoneUsageDescription": "Non utilisé."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#28655c"
      },
      "package": "com.almoutahabbina.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#28655c"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Pour calculer les horaires de prière selon votre position."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
